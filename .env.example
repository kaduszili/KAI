# Server
PORT=3001
NODE_ENV=development

# Database (Supabase direct connection URL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Auth
JWT_SECRET=change-me-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# Encryption key for stored API keys (32-byte hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-64-char-hex-string

# Platform OpenAI key (Super Admin plan — used when customer is on pro plan)
PLATFORM_OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# CORS — origin of the admin dashboard
ADMIN_ORIGIN=http://localhost:5173
